# Database URL (SQLite for development, PostgreSQL for production)
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./dev.db

# CORS Origins (comma-separated, no spaces)
# Production example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Settings
APP_NAME=PodCraft API
APP_VERSION=0.1.0
DEBUG=true

# Secret Key (MUST change in production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis URL for Celery task queue
REDIS_URL=redis://localhost:6379/0

# Storage path (local filesystem for dev; S3/MinIO for production)
STORAGE_PATH=storage

# TTS Provider Configuration
# Primary provider: "minimax" or "edge_tts"
TTS_PROVIDER_PRIMARY=minimax
# MiniMax Speech-2.8-turbo
TTS_MINIMAX_API_KEY=your-minimax-key-here
TTS_MINIMAX_API_BASE=https://api.minimax.chat
TTS_MINIMAX_MAX_QPS=10
# Edge-TTS (free fallback, no API key needed)
TTS_EDGETTS_ENABLED=true

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=backend.log
