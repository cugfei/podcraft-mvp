# Database URL (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./dev.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Settings
APP_NAME=PodCraft API
APP_VERSION=0.1.0
DEBUG=true

# Secret Key (change in production)
SECRET_KEY=change-me-in-production

# Redis URL for Celery task queue
REDIS_URL=redis://localhost:6379/0

# TTS Provider Configuration
# Primary provider: "minimax" or "edge_tts"
TTS_PROVIDER_PRIMARY=minimax
# MiniMax Speech-2.8-turbo
TTS_MINIMAX_API_KEY=your-minimax-key-here
TTS_MINIMAX_API_BASE=https://api.minimax.chat
TTS_MINIMAX_MAX_QPS=10
# Edge-TTS (free fallback, no API key needed)
TTS_EDGETTS_ENABLED=true
